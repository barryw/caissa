; Rules-only reusable engine tests.

suites {
  suite("Reusable Rules Engine Boundary") {
    symbols("/code/build/rules_harness.sym")
    load("/code/build/rules_harness.prg", strip_header = true)

    setup {
      memfill([Board88], 128, $30)
      [currentplayer] = $01
      [whitekingsq] = $44
      [blackkingsq] = $00
      [castlerights] = $00
      [enpassantsq] = $ff
      [SearchDepth] = $00
      [SearchSide] = $80
    }

    test("rules-api-generates-legal-moves", "ChessGenerateLegalMoves works without AI search") {
      [Board88] + $44 = $b6
      [Board88] + $00 = $36

      jsr([ChessGenerateLegalMoves], stop_on_rts = true, fail_on_brk = true)

      assert(a == $08, "White king in the center should have 8 legal moves")
      assert(peekbyte([MoveCount]) == $08, "MoveCount should match API return")
    }

    test("rules-api-attack-detection", "ChessIsSquareAttacked exposes attack rules without AI") {
      [Board88] + $40 = $34
      [Board88] + $47 = $b6

      $26 = $47
      $27 = $00

      jsr([ChessIsSquareAttacked], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Black rook should attack h4")
    }

    test("rules-api-commit-move", "ChessCommitMove applies permanent moves and advances side") {
      [Board88] + $74 = $b6
      [Board88] + $04 = $36
      [Board88] + $64 = $b1
      [whitekingsq] = $74
      [blackkingsq] = $04

      a = $64
      x = $44
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([Board88] + $64) == $30, "e2 should be empty after commit")
      assert(peekbyte([Board88] + $44) == $b1, "e4 should contain the pawn after commit")
      assert(peekbyte([currentplayer]) == $00, "Committed white move should pass turn to black")
      assert(peekbyte([enpassantsq]) == $54, "Double push should set e3 en passant square")
    }
  }
}
