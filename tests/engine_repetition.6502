; Repetition-draw regressions for host-facing engine APIs.

suites {
  suite("Engine Repetition Draw") {
    symbols("/code/build/engine_harness.sym")
    load("/code/build/engine_harness.prg", strip_header = true)

    setup {
      jsr([ChessClearPositionHistory], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      memfill([WhitePieceList], 16, $ff)
      memfill([BlackPieceList], 16, $ff)

      [Board88] + $74 = $b6          ; WHITE_KING e1
      [Board88] + $64 = $b1          ; WHITE_PAWN e2
      [Board88] + $04 = $36          ; BLACK_KING e8
      [Board88] + $14 = $31          ; BLACK_PAWN e7
      [whitekingsq] = $74
      [blackkingsq] = $04
      [WhitePieceList] + $00 = $74
      [WhitePieceList] + $01 = $64
      [WhitePieceCount] = $02
      [BlackPieceList] + $00 = $04
      [BlackPieceList] + $01 = $14
      [BlackPieceCount] = $02
      [currentplayer] = $01
      [castlerights] = $00
      [enpassantsq] = $ff
      [SearchDepth] = $00
      [SearchSide] = $80
      [EngineGameState] = $00
    }

    test("opening-two-plies-are-not-repetition", "Fresh host history does not report repetition after e4 e5") {
      jsr([ChessRecordPosition], stop_on_rts = true, fail_on_brk = true)

      ; 1. e4
      [Board88] + $64 = $30
      [Board88] + $44 = $b1
      [WhitePieceList] + $01 = $44
      [currentplayer] = $00
      jsr([ChessRecordPosition], stop_on_rts = true, fail_on_brk = true)

      ; ... e5
      [Board88] + $14 = $30
      [Board88] + $34 = $31
      [BlackPieceList] + $01 = $34
      [currentplayer] = $01
      jsr([ChessRecordPosition], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([HistoryCount]) == $03, "Opening line should record three distinct positions")

      jsr([ChessCheckRepetition], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Two plies from the initial position are not threefold repetition")

      jsr([ChessCheckGameState], stop_on_rts = true, fail_on_brk = true)

      assert(a != $05, "Opening line should not report GAME_DRAW_REPETITION")
      assert(peekbyte([EngineGameState]) != $05, "EngineGameState should not report repetition")
    }

    test("commit-opening-two-plies-are-not-repetition", "Committed game moves own history and no-progress clocks") {
      jsr([ChessBeginGame], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([HistoryCount]) == $01, "ChessBeginGame should record the initial position")

      ; 1. e4
      a = $64
      x = $44
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)

      assert(a == $00, "White pawn move should leave a normal playable game")
      assert(peekbyte([currentplayer]) == $00, "Black should be on move after white commits")
      assert(peekbyte([HalfmoveClock]) == $00, "Pawn move should reset the halfmove clock")
      assert(peekbyte([HistoryCount]) == $02, "Committed white move should record the position")
      assert(peekbyte([Board88] + $44) == $b1, "White pawn should be on e4")

      ; ... e5
      a = $14
      x = $34
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)

      assert(a == $00, "Black pawn move should leave a normal playable game")
      assert(peekbyte([currentplayer]) == $01, "White should be on move after black commits")
      assert(peekbyte([FullmoveNumber]) == $02, "Fullmove number should advance after black moves")
      assert(peekbyte([HalfmoveClock]) == $00, "Black pawn move should reset the halfmove clock")
      assert(peekbyte([HistoryCount]) == $03, "Committed black move should record the position")
      assert(peekbyte([EngineGameState]) != $05, "Two opening plies should not report repetition")
    }

    test("committed-rook-chase-reports-claim-and-auto-draw", "Rook-chase loops report threefold and fivefold repetition") {
      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6          ; WHITE_KING e1
      [Board88] + $70 = $b4          ; WHITE_ROOK a1
      [Board88] + $07 = $36          ; BLACK_KING h8
      [whitekingsq] = $74
      [blackkingsq] = $07
      [currentplayer] = $01
      [castlerights] = $00
      [enpassantsq] = $ff

      jsr([ChessBeginGame], stop_on_rts = true, fail_on_brk = true)

      ; Cycle 1: Ra2, Kg8, Ra1, Kh8.
      a = $70
      x = $60
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $07
      x = $06
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $60
      x = $70
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $06
      x = $07
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)

      assert(a == $00, "First repeated cycle should not be drawable yet")

      ; Cycle 2 reaches the third occurrence of the initial position.
      a = $70
      x = $60
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $07
      x = $06
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $60
      x = $70
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $06
      x = $07
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)

      assert(a == $05, "Third occurrence should report a claimable repetition draw")
      assert(peekbyte([EngineGameState]) == $05, "EngineGameState should report claimable repetition")
      assert(peekbyte([RepeatCount]) == $03, "Threefold draw should count three occurrences")

      ; Cycles 3 and 4 reach the automatic fivefold repetition draw.
      a = $70
      x = $60
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $07
      x = $06
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $60
      x = $70
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $06
      x = $07
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)

      a = $70
      x = $60
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $07
      x = $06
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $60
      x = $70
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)
      a = $06
      x = $07
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)

      assert(a == $08, "Fifth occurrence should report automatic repetition draw")
      assert(peekbyte([EngineGameState]) == $08, "EngineGameState should report automatic repetition")
      assert(peekbyte([RepeatCount]) == $05, "Fivefold draw should count five occurrences")
    }

    test("committed-no-progress-draws-are-reported", "50-move claim and 75-move automatic draw use committed clocks") {
      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6          ; WHITE_KING e1
      [Board88] + $70 = $b4          ; WHITE_ROOK a1
      [Board88] + $07 = $36          ; BLACK_KING h8
      [whitekingsq] = $74
      [blackkingsq] = $07
      [currentplayer] = $01
      [castlerights] = $00
      [enpassantsq] = $ff

      jsr([ChessBeginGame], stop_on_rts = true, fail_on_brk = true)

      [HalfmoveClock] = $63          ; 99 halfmoves
      a = $70
      x = $60
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)

      assert(a == $04, "100 halfmoves should report a 50-move claim")
      assert(peekbyte([HalfmoveClock]) == $64, "Halfmove clock should advance to 100")

      ; Reset the board for the 75-move automatic threshold.
      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $70 = $b4
      [Board88] + $07 = $36
      [whitekingsq] = $74
      [blackkingsq] = $07
      [currentplayer] = $01
      [castlerights] = $00
      [enpassantsq] = $ff
      jsr([ChessBeginGame], stop_on_rts = true, fail_on_brk = true)

      [HalfmoveClock] = $95          ; 149 halfmoves
      a = $70
      x = $60
      jsr([ChessCommitMove], stop_on_rts = true, fail_on_brk = true)

      assert(a == $07, "150 halfmoves should report automatic 75-move draw")
      assert(peekbyte([HalfmoveClock]) == $96, "Halfmove clock should advance to 150")
      assert(peekbyte([EngineGameState]) == $07, "EngineGameState should report automatic 75-move draw")
    }

    test("duplicate-host-records-are-idempotent", "Repeated host calls for the same position do not create a draw") {
      jsr([ChessRecordPosition], stop_on_rts = true, fail_on_brk = true)
      jsr([ChessRecordPosition], stop_on_rts = true, fail_on_brk = true)
      jsr([ChessRecordPosition], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([HistoryCount]) == $01, "Same committed position should only be recorded once consecutively")

      jsr([ChessCheckRepetition], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Duplicate host records should not create repetition draw")
    }
  }
}
