      assert(peekbyte([EvalScore]) == $e4, "White rook attacked by a bishop should lose minor-pressure value")
      assert(peekbyte([EvalScore] + $01) == $ff, "White rook pressure should keep score negative")
      a = $80

      jsr([SideHasMinorAttackedMajor], stop_on_rts = true, fail_on_brk = true)

