; Headless reusable engine tests.
; These load tests/engine_harness.prg instead of the full C64 chess program.

suites {
  suite("Headless Engine Core") {
    symbols("/code/build/engine_harness.sym")
    load("/code/build/engine_harness.prg", strip_header = true)

    setup {
      memfill([Board88], 128, $30)
      [currentplayer] = $01
      [whitekingsq] = $44
      [blackkingsq] = $00
      [castlerights] = $00
      [enpassantsq] = $ff
      [SearchDepth] = $00
      [SearchSide] = $80
    }

    test("headless-engine-generates-legal-moves", "ChessGenerateLegalMoves works without the app shell") {
      [Board88] + $44 = $b6
      [Board88] + $00 = $36

      jsr([ChessGenerateLegalMoves], stop_on_rts = true, fail_on_brk = true)

      assert(a == $08, "White king in the center should have 8 legal moves")
      assert(peekbyte([MoveCount]) == $08, "MoveCount should match API return")
    }

    test("search-aspiration-window-bounds", "Aspiration setup derives a bounded window from prior iteration score") {
      [IterDepth] = $02
      [IterScore] = $0a
      [SearchAspirationAttempts] = $00

      jsr([SetupAspirationWindow], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($e8) == $f6, "Aspiration alpha should be previous score minus window")
      assert(peekbyte($e9) == $1e, "Aspiration beta should be previous score plus window")
      assert(peekbyte([SearchAspirationAttempts]) == $01, "Aspiration attempt counter should increment")
      assert(peekbyte([SearchAspirationActive]) == $01, "Aspiration should be marked active")

      [IterDepth] = $01
      jsr([SetupAspirationWindow], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($e8) == $80, "Depth-one search should use full alpha")
      assert(peekbyte($e9) == $7f, "Depth-one search should use full beta")
      assert(peekbyte([SearchAspirationActive]) == $00, "Depth-one search should not use aspiration")
    }

    test("negamax-uses-pvs-on-later-deep-moves", "Depth-four search probes later moves with PVS") {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      [SearchDepth] = $00
      [SearchSide] = $80
      [SearchPVSSearches] = $00
      [SearchPVSResearches] = $00

      [Board88] + $44 = $b6
      [Board88] + $00 = $36
      jsr([InitPieceLists], stop_on_rts = true, fail_on_brk = true)

      $e8 = $80
      $e9 = $7f
      a = $04
      jsr([Negamax], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([SearchDepth]) == $00, "Negamax should restore SearchDepth")
      assert(peekbyte([SearchPVSSearches]) > $00, "Depth-four search should use PVS probes")
    }

    test("history-rewards-quiet-cutoff", "Quiet beta cutoffs update compact history ordering") {
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      $f0 = $64
      $f1 = $44
      a = $04
      jsr([StoreHistory], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([SearchHistoryActive]) == $01, "StoreHistory should activate history ordering")
      assert(peekbyte([SearchHistoryUpdates]) == $01, "StoreHistory should report one update")
      assert(peekbyte([HistoryScores] + $0c) == $10, "History score should use depth-weighted compact from/to index")

      [HistoryScores] + $0c = $f0
      $f0 = $64
      $f1 = $44
      a = $07
      jsr([StoreHistory], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([HistoryScores] + $0c) == $ff, "History scores should saturate at 255")
    }

    test("history-orders-quiet-moves", "Move ordering promotes the best historical quiet move") {
      jsr([ClearKillers], stop_on_rts = true, fail_on_brk = true)
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [MoveCount] = $03
      [MoveListFrom] + $00 = $60
      [MoveListTo] + $00 = $50
      [MoveListFrom] + $01 = $64
      [MoveListTo] + $01 = $44
      [MoveListFrom] + $02 = $67
      [MoveListTo] + $02 = $57
      [HistoryScores] + $0c = $40
      [SearchHistoryActive] = $01
      [SearchDepth] = $01

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $64, "Best historical quiet move should be promoted")
      assert(peekbyte([MoveListTo]) == $44, "Promoted history move should keep its destination")
    }

    test("countermove-orders-quiet-replies", "Move ordering promotes quiet replies that refuted the previous move destination") {
      jsr([ClearKillers], stop_on_rts = true, fail_on_brk = true)
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      [SearchDepth] = $02
      [LastMoveToByDepth] + $02 = $44
      $f0 = $64
      $f1 = $54
      jsr([StoreCounterMove], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [MoveCount] = $03
      [MoveListFrom] + $00 = $60
      [MoveListTo] + $00 = $50
      [MoveListFrom] + $01 = $64
      [MoveListTo] + $01 = $54
      [MoveListFrom] + $02 = $67
      [MoveListTo] + $02 = $57

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $64, "Countermove reply should be promoted")
      assert(peekbyte([MoveListTo]) == $54, "Countermove destination should move to the front")
    }

    test("ordering-keeps-bad-captures-behind-quiets", "Stale killers cannot promote captures rejected by swap-off") {
      jsr([ClearKillers], stop_on_rts = true, fail_on_brk = true)
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [Board88] + $70 = $b6
      [Board88] + $07 = $36
      [Board88] + $67 = $b2
      [Board88] + $64 = $b5
      [Board88] + $44 = $31
      [Board88] + $04 = $34
      [whitekingsq] = $70
      [blackkingsq] = $07
      [SearchDepth] = $02
      a = $64
      x = $44
      y = $02
      jsr([StoreKiller], stop_on_rts = true, fail_on_brk = true)

      [MoveCount] = $02
      [MoveListFrom] + $00 = $67
      [MoveListTo] + $00 = $57
      [MoveListFrom] + $01 = $64
      [MoveListTo] + $01 = $44

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $67, "Bad defended capture should stay behind ordinary quiets")
      assert(peekbyte([MoveListTo]) == $57, "Quiet move should remain first")
    }

    test("ordering-boosts-recaptures", "MVV-LVA gives forced recaptures a bounded score bump") {
      jsr([ClearKillers], stop_on_rts = true, fail_on_brk = true)
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $00 = $36
      [Board88] + $70 = $b4
      [Board88] + $64 = $b2
      [Board88] + $43 = $33
      [Board88] + $44 = $31
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchDepth] = $01
      [LastMoveWasCaptureByDepth] + $01 = $01
      [LastMoveToByDepth] + $01 = $44

      [MoveCount] = $02
      [MoveListFrom] + $00 = $70
      [MoveListTo] + $00 = $43
      [MoveListFrom] + $01 = $64
      [MoveListTo] + $01 = $44

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $64, "Recapture should move ahead of a slightly higher nominal MVV-LVA capture")
      assert(peekbyte([MoveListTo]) == $44, "Recapture destination should be the previous capture square")
    }

    test("tt-keeps-deeper-current-generation-entry", "Transposition table replacement prefers deeper entries") {
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      [ZobristHash] = $02
      [ZobristHash] + $01 = $44
      [TTScoreLo] = $2a
      [TTScoreHi] = $00
      [TTStoreFrom] = $44
      [TTStoreTo] = $23
      [TTStoreUseMove] = $01
      a = $05
      x = $00
      jsr([TTStore], stop_on_rts = true, fail_on_brk = true)

      [TTScoreLo] = $11
      [TTScoreHi] = $00
      [TTStoreFrom] = $60
      [TTStoreTo] = $50
      [TTStoreUseMove] = $01
      a = $02
      x = $00
      jsr([TTStore], stop_on_rts = true, fail_on_brk = true)

      a = $05
      jsr([TTProbe], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([TTHit]) == $01, "Deeper entry should still satisfy a deep probe")
      assert(peekbyte([TTScoreLo]) == $2a, "Shallow replacement should not overwrite deeper score")
      assert(peekbyte([TTBestFrom]) == $44, "Shallow replacement should not overwrite deeper move")

      [TTScoreLo] = $33
      [TTScoreHi] = $00
      [TTStoreFrom] = $61
      [TTStoreTo] = $51
      [TTStoreUseMove] = $01
      a = $06
      x = $00
      jsr([TTStore], stop_on_rts = true, fail_on_brk = true)

      a = $06
      jsr([TTProbe], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([TTHit]) == $01, "Deeper replacement should satisfy the deeper probe")
      assert(peekbyte([TTScoreLo]) == $33, "Deeper replacement should overwrite the old score")
      assert(peekbyte([TTBestFrom]) == $61, "Deeper replacement should overwrite the old move")

      [TTScoreLo] = $12
      [TTScoreHi] = $00
      [TTStoreFrom] = $62
      [TTStoreTo] = $52
      [TTStoreUseMove] = $01
      a = $06
      x = $01
      jsr([TTStore], stop_on_rts = true, fail_on_brk = true)

      a = $06
      jsr([TTProbe], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([TTScoreLo]) == $33, "Same-depth bound should not replace an exact TT score")
      assert(peekbyte([TTBestFrom]) == $61, "Same-depth bound should not replace an exact TT move")

      [TTScoreLo] = $44
      [TTScoreHi] = $00
      [TTStoreFrom] = $63
      [TTStoreTo] = $53
      [TTStoreUseMove] = $01
      a = $06
      x = $00
      jsr([TTStore], stop_on_rts = true, fail_on_brk = true)

      a = $06
      jsr([TTProbe], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([TTScoreLo]) == $44, "Same-depth exact score should refresh the TT entry")
      assert(peekbyte([TTBestFrom]) == $63, "Same-depth exact move should refresh the TT entry")
    }

    test("make-unmake-maintains-piece-lists", "Search move state keeps compact piece lists current") {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $44 = $b2
      [Board88] + $04 = $36
      [Board88] + $23 = $35
      [whitekingsq] = $74
      [blackkingsq] = $04
      [SearchDepth] = $00
      [SearchSide] = $80
      jsr([InitPieceLists], stop_on_rts = true, fail_on_brk = true)
      jsr([ComputeZobristHash], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([ZobristHashValid]) == $01, "Full hash computation should mark cached Zobrist hash valid")

      a = $44
      x = $23
      jsr([MakeMove], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([ZobristHashValid]) == $00, "MakeMove should dirty the cached Zobrist hash")
      assert(peekbyte([WhitePieceCount]) == $02, "Capture should preserve white piece count")
      assert(peekbyte([BlackPieceCount]) == $01, "Capture should remove one black piece")
      assert(peekbyte([WhitePieceList]) == $23, "Moved white knight should be listed on d6")
      assert(peekbyte([BlackPieceList]) == $04, "Only black king should remain listed")
      jsr([ComputeZobristHash], stop_on_rts = true, fail_on_brk = true)
      assert(peekbyte([ZobristHashValid]) == $01, "Hash recomputation after MakeMove should refresh the cache flag")

      a = $44
      x = $23
      jsr([UnmakeMove], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([ZobristHashValid]) == $00, "UnmakeMove should dirty the cached Zobrist hash")
      assert(peekbyte([WhitePieceCount]) == $02, "Unmake should restore white piece count")
      assert(peekbyte([BlackPieceCount]) == $02, "Unmake should restore black piece count")
      assert(peekbyte([WhitePieceList]) == $44, "White knight should return to e4 in the list")
      assert(peekbyte([BlackPieceList] + $01) == $23, "Captured black queen should return to d6 in the list")
    }

    test("ordering-promotes-forcing-quiets", "Move ordering searches quiet checks and promotions before ordinary quiet moves") {
      jsr([ClearKillers], stop_on_rts = true, fail_on_brk = true)
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [Board88] + $70 = $b6
      [Board88] + $77 = $b4
      [Board88] + $04 = $36
      [whitekingsq] = $70
      [blackkingsq] = $04
      [MoveCount] = $02
      [MoveListFrom] + $00 = $77
      [MoveListTo] + $00 = $67
      [MoveListFrom] + $01 = $77
      [MoveListTo] + $01 = $74

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $77, "Quiet checking rook move should be promoted")
      assert(peekbyte([MoveListTo]) == $74, "Quiet checking move should move to the front")

      memfill([Board88], 128, $30)
      [Board88] + $70 = $b6
      [Board88] + $77 = $b4
      [Board88] + $14 = $b1
      [Board88] + $00 = $36
      [whitekingsq] = $70
      [blackkingsq] = $00
      [MoveCount] = $02
      [MoveListFrom] + $00 = $77
      [MoveListTo] + $00 = $67
      [MoveListFrom] + $01 = $14
      [MoveListTo] + $01 = $04

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $14, "Quiet promotion should be promoted before ordinary quiets")
      assert(peekbyte([MoveListTo]) == $04, "Quiet promotion destination should move to the front")

      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $64 = $b2
      [Board88] + $04 = $36
      [Board88] + $37 = $35
      [whitekingsq] = $74
      [blackkingsq] = $04
      [SearchDepth] = $00
      [MoveCount] = $02
      [MoveListFrom] + $00 = $74
      [MoveListTo] + $00 = $73
      [MoveListFrom] + $01 = $64
      [MoveListTo] + $01 = $45

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $64, "Quiet knight fork threat should be promoted before ordinary quiets")
      assert(peekbyte([MoveListTo]) == $45, "Threatening quiet move destination should move to the front")
    }

    test("root-shortcut-finds-mate-in-one", "Root tactical shortcut takes immediate mate before search") {
      memfill([Board88], 128, $30)
      [Board88] + $00 = $36
      [Board88] + $21 = $b6
      [Board88] + $67 = $b4
      [whitekingsq] = $21
      [blackkingsq] = $00
      [SearchDepth] = $00
      [SearchSide] = $80
      [BestMoveFrom] = $ff
      [BestMoveTo] = $ff
      jsr([InitPieceLists], stop_on_rts = true, fail_on_brk = true)

      jsr([TryRootMateInOne], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Root mate shortcut should find a mate")
      assert(peekbyte([BestMoveFrom]) == $67, "Mate shortcut should move rook from h2")
      assert(peekbyte([BestMoveTo]) == $07, "Mate shortcut should play Rh8#")
      assert(peekbyte([SearchDepth]) == $00, "Mate shortcut should restore search depth")
      assert(peekbyte([SearchSide]) == $80, "Mate shortcut should restore side to move")
    }

    test("root-penalizes-move-allowing-mate-in-one", "Root scoring rejects moves that hand the opponent immediate mate") {
      memfill([Board88], 128, $30)
      [Board88] + $00 = $34
      [Board88] + $02 = $33
      [Board88] + $03 = $34
      [Board88] + $06 = $36
      [Board88] + $11 = $31
      [Board88] + $15 = $31
      [Board88] + $16 = $31
      [Board88] + $17 = $31
      [Board88] + $31 = $31
      [Board88] + $45 = $32
      [Board88] + $55 = $35
      [Board88] + $46 = $b1
      [Board88] + $50 = $b1
      [Board88] + $51 = $b3
      [Board88] + $72 = $b4
      [Board88] + $74 = $b6
      [Board88] + $76 = $b4
      [whitekingsq] = $74
      [blackkingsq] = $06
      [currentplayer] = $01
      [SearchSide] = $80
      [SearchDepth] = $00
      [castlerights] = $00
      [enpassantsq] = $ff

      memfill([WhitePieceList], 16, $ff)
      memfill([BlackPieceList], 16, $ff)
      [WhitePieceList] + $00 = $74
      [WhitePieceList] + $01 = $46
      [WhitePieceList] + $02 = $50
      [WhitePieceList] + $03 = $51
      [WhitePieceList] + $04 = $72
      [WhitePieceList] + $05 = $76
      [WhitePieceCount] = $06
      [BlackPieceList] + $00 = $06
      [BlackPieceList] + $01 = $00
      [BlackPieceList] + $02 = $02
      [BlackPieceList] + $03 = $03
      [BlackPieceList] + $04 = $11
      [BlackPieceList] + $05 = $15
      [BlackPieceList] + $06 = $16
      [BlackPieceList] + $07 = $17
      [BlackPieceList] + $08 = $31
      [BlackPieceList] + $09 = $45
      [BlackPieceList] + $0a = $55
      [BlackPieceCount] = $0b

      [NegamaxState] + $03 = $51
      [NegamaxState] + $04 = $60
      [BestMoveFrom] = $72
      [BestMoveTo] = $73
      $eb = $20

      jsr([ApplyRootAllowsMatePenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $80, "Move allowing Qe2 mate should be rejected")
      assert(peekbyte([BestMoveFrom]) == $72, "Mate probe should restore current best move from")
      assert(peekbyte([BestMoveTo]) == $73, "Mate probe should restore current best move to")
      assert(peekbyte([SearchDepth]) == $00, "Mate probe should restore search depth")
      assert(peekbyte([SearchSide]) == $80, "Mate probe should restore side to move")

      [NegamaxState] + $03 = $51
      [NegamaxState] + $04 = $33
      $eb = $78

      jsr([ApplyRootAllowsMatePenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $80, "Mate-score candidates still cannot allow mate in one")
      assert(peekbyte([SearchDepth]) == $00, "Second mate probe should restore search depth")
      assert(peekbyte([SearchSide]) == $80, "Second mate probe should restore side to move")

      [NegamaxState] + $03 = $51
      [NegamaxState] + $04 = $15
      $eb = $20

      jsr([ApplyRootAllowsMatePenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $20, "Checking capture that stops mate should keep its score")
      assert(peekbyte([SearchDepth]) == $00, "Safe mate probe should restore search depth")
      assert(peekbyte([SearchSide]) == $80, "Safe mate probe should restore side to move")

      [BestMoveFrom] = $ff
      [BestMoveTo] = $ff

      jsr([TryRootAvoidMateThreatMove], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Root emergency should find a move that stops mate")
      assert(peekbyte([BestMoveFrom]) == $51, "Mate-threat escape should use the active bishop")
      assert(peekbyte([BestMoveTo]) == $73, "Mate-threat escape should block the mating queen on d1")
      assert(peekbyte([SearchDepth]) == $00, "Mate-threat escape should restore search depth")
      assert(peekbyte([SearchSide]) == $80, "Mate-threat escape should restore side to move")

      [MoveCount] = $02
      [MoveListFrom] + $00 = $51
      [MoveListTo] + $00 = $60
      [MoveListFrom] + $01 = $51
      [MoveListTo] + $01 = $73
      [BestMoveFrom] = $ff
      [BestMoveTo] = $ff

      jsr([SetSafeRootFallbackMove], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([BestMoveFrom]) == $51, "Fallback should skip a bishop move that allows Qe2 mate")
      assert(peekbyte([BestMoveTo]) == $73, "Fallback should keep the bishop block that stops mate")
      assert(peekbyte([SearchDepth]) == $00, "Fallback mate probe should restore search depth")
      assert(peekbyte([SearchSide]) == $80, "Fallback mate probe should restore side to move")

      memfill([Board88], 128, $30)
      [Board88] + $00 = $34
      [Board88] + $04 = $36
      [Board88] + $07 = $34
      [Board88] + $12 = $31
      [Board88] + $15 = $31
      [Board88] + $16 = $31
      [Board88] + $17 = $31
      [Board88] + $20 = $31
      [Board88] + $22 = $31
      [Board88] + $25 = $32
      [Board88] + $32 = $33
      [Board88] + $40 = $b1
      [Board88] + $44 = $b1
      [Board88] + $55 = $b1
      [Board88] + $57 = $b1
      [Board88] + $61 = $35
      [Board88] + $66 = $b1
      [Board88] + $73 = $b4
      [Board88] + $75 = $b6
      [Board88] + $77 = $b4
      [whitekingsq] = $75
      [blackkingsq] = $04
      [SearchSide] = $80
      [SearchDepth] = $00
      [castlerights] = $00
      [enpassantsq] = $ff
      [BestMoveFrom] = $ff
      [BestMoveTo] = $ff
      jsr([InitPieceLists], stop_on_rts = true, fail_on_brk = true)

      jsr([TryRootAvoidMateThreatMove], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Root emergency should see Qb2-f2 mate from four files away")
      assert(peekbyte([BestMoveFrom]) != $ff, "Wide mate-threat escape should pick a legal source")
      assert(peekbyte([BestMoveTo]) != $ff, "Wide mate-threat escape should pick a legal destination")
      assert(peekbyte([SearchDepth]) == $00, "Wide mate-threat escape should restore search depth")
      assert(peekbyte([SearchSide]) == $80, "Wide mate-threat escape should restore side to move")

      memfill([Board88], 128, $30)
      [Board88] + $00 = $34
      [Board88] + $02 = $33
      [Board88] + $04 = $36
      [Board88] + $06 = $32
      [Board88] + $07 = $34
      [Board88] + $10 = $31
      [Board88] + $11 = $31
      [Board88] + $12 = $31
      [Board88] + $14 = $33
      [Board88] + $15 = $31
      [Board88] + $34 = $b2
      [Board88] + $42 = $b1
      [Board88] + $43 = $b1
      [Board88] + $45 = $31
      [Board88] + $47 = $31
      [Board88] + $55 = $b4
      [Board88] + $63 = $35
      [Board88] + $65 = $b1
      [Board88] + $66 = $b1
      [Board88] + $67 = $b1
      [Board88] + $74 = $b4
      [Board88] + $76 = $b6
      [whitekingsq] = $76
      [blackkingsq] = $04
      [SearchSide] = $80
