      jsr([TryNullMovePrune], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Low static eval should disable null move pruning")
      assert(peekbyte([SearchNullMoveAttempts]) == $00, "Low static eval should not count as a null move attempt")
      assert(peekbyte([SearchNullMoveEvalSkips]) == $01, "Low static eval should count as an eval-gated skip")
    }

