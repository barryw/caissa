      assert(peekbyte([EvalScore] + $01) == $ff, "Black invasion bonus should keep score negative")

      [EvalScore] = $00
      [EvalScore] + $01 = $00
      $f0 = $73
      $f1 = $80
      $f2 = $04

      jsr([EvaluateSeventhRankPressure], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $00, "Home-rank rooks should not get the invasion bonus")
    }

    test("eval-rewards-knight-outposts", "Knight outposts require central support and no pawn chase") {
