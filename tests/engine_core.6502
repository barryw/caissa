    test("eval-rewards-bishop-pair", "Evaluation counts bishops and applies the bishop-pair bonus") {
      [EvalScore] = $00
      [EvalScore] + $01 = $00
      [EvalWhiteBishopCount] = $02
      [EvalBlackBishopCount] = $01

      jsr([ApplyBishopPairBonus], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $14, "White bishop pair should add the bishop-pair bonus")
      assert(peekbyte([EvalScore] + $01) == $00, "White bishop-pair bonus should keep score positive")

      [EvalScore] = $00
      [EvalScore] + $01 = $00
      [EvalWhiteBishopCount] = $01
      [EvalBlackBishopCount] = $02

      jsr([ApplyBishopPairBonus], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $ec, "Black bishop pair should subtract the bishop-pair bonus")
      assert(peekbyte([EvalScore] + $01) == $ff, "Black bishop-pair bonus should keep score negative")

      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $04 = $36
      [Board88] + $42 = $b3
      [Board88] + $45 = $b3
      [Board88] + $22 = $33
      [whitekingsq] = $74
      [blackkingsq] = $04

      jsr([EvaluatePosition], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalWhiteBishopCount]) == $02, "EvaluatePosition should count both white bishops")
      assert(peekbyte([EvalBlackBishopCount]) == $01, "EvaluatePosition should count the single black bishop")
    }

