    test("headless-engine-finds-promotion", "ChessFindBestMove handles a headless promotion shortcut", timeout = 13000000) {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      [difficulty] = $02
      [currentplayer] = $00
      [castlerights] = $00
      [enpassantsq] = $ff

      memfill([Board88], 128, $30)
      [Board88] + $70 = $b6
      [Board88] + $07 = $36
      [Board88] + $64 = $31
      [whitekingsq] = $70
      [blackkingsq] = $07

      memfill([WhitePieceList], 16, $ff)
      memfill([BlackPieceList], 16, $ff)
      [WhitePieceList] + $00 = $70
      [WhitePieceCount] = $01
      [BlackPieceList] + $00 = $07
      [BlackPieceList] + $01 = $64
      [BlackPieceCount] = $02

      jsr([ChessFindBestMove], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([BestMoveFrom]) == $64, "Headless engine should move black pawn from e2")
      assert(peekbyte([BestMoveTo]) == $74, "Headless engine should promote to queen on e1")
      assert(peekbyte([SearchDepth]) == $00, "SearchDepth should return to zero")
      assert(peekbyte([SearchCompletedDepth]) == $00, "Promotion shortcut should not claim iterative depth")
      assert(peekbyte([SearchRootMoveCount]) == $00, "Promotion shortcut should not claim searched root moves")
      assert(peekbyte([SearchUsedBook]) == $00, "Headless test platform should not use a book")
    }

    test("headless-engine-search-reports-counters", "ChessFindBestMove reports search counters when no shortcut fires", timeout = 13000000) {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      [difficulty] = $00
      [currentplayer] = $01
      [castlerights] = $00
      [enpassantsq] = $ff

      memfill([Board88], 128, $30)
      [Board88] + $44 = $b6
      [Board88] + $00 = $36
      [Board88] + $64 = $b1
      [Board88] + $10 = $31
      [whitekingsq] = $44
      [blackkingsq] = $00

      memfill([WhitePieceList], 16, $ff)
      memfill([BlackPieceList], 16, $ff)
      [WhitePieceList] + $00 = $44
      [WhitePieceList] + $01 = $64
      [WhitePieceCount] = $02
      [BlackPieceList] + $00 = $00
      [BlackPieceList] + $01 = $10
      [BlackPieceCount] = $02

      jsr([ChessFindBestMove], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([BestMoveFrom]) != $ff, "Headless search should find a move")
      assert(peekbyte([SearchDepth]) == $00, "SearchDepth should return to zero")
      assert(peekbyte([SearchCompletedDepth]) > $00, "Headless search should report completed depth")
      assert(peekbyte([SearchRootMoveCount]) > $00, "Headless search should report root moves")
      assert(peekbyte([SearchUsedBook]) == $00, "Headless test platform should not use a book")
      assert(peekbyte([SearchAspirationAttempts]) > $00, "Iterative deepening should use aspiration after depth one")
    }

    test("headless-engine-extended-search-keeps-legal-root-move", "Extended hard search must not corrupt the root move", timeout = 300000000) {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [Board88] + $00 = $34
      [Board88] + $02 = $33
      [Board88] + $03 = $35
      [Board88] + $04 = $36
      [Board88] + $05 = $33
      [Board88] + $06 = $32
      [Board88] + $07 = $34
      [Board88] + $10 = $31
      [Board88] + $11 = $31
      [Board88] + $12 = $31
      [Board88] + $16 = $31
      [Board88] + $17 = $31
      [Board88] + $20 = $32
      [Board88] + $23 = $31
      [Board88] + $34 = $31
      [Board88] + $35 = $b1
      [Board88] + $36 = $b2
      [Board88] + $43 = $b1
      [Board88] + $52 = $b2
      [Board88] + $60 = $b1
      [Board88] + $61 = $b1
      [Board88] + $62 = $b1
      [Board88] + $66 = $b1
      [Board88] + $67 = $b1
      [Board88] + $70 = $b4
      [Board88] + $72 = $b3
      [Board88] + $73 = $b5
      [Board88] + $74 = $b6
      [Board88] + $75 = $b3
      [Board88] + $77 = $b4

      [currentplayer] = $01
      [difficulty] = $02
      [whitekingsq] = $74
      [blackkingsq] = $04
      [castlerights] = $03
      [enpassantsq] = $24
      [HistoryCount] = $00
      [BestMoveFrom] = $ff
      [BestMoveTo] = $ff

      jsr([ChessFindBestMove], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([BestMoveFrom]) != $ff, "Hard search should find a concrete source")
      assert(peekbyte([BestMoveTo]) != $ff, "Hard search should find a concrete destination")
      assert(peekbyte([BestMoveTo]) != $74, "Hard search must not return a move onto its own king")
      assert(peekbyte([Board88] + $74) == $b6, "Search should leave the white king on e1")
    }

    test("sanitize-host-state-repairs-input", "SanitizeHostState re-derives king squares and drops impossible castle/ep state") {
      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $04 = $36
      [Board88] + $70 = $b4
      [Board88] + $30 = $31
      [whitekingsq] = $44
      [blackkingsq] = $40
      [SearchSide] = $80
      [castlerights] = $0f
      [enpassantsq] = $20

      jsr([SanitizeHostState], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([whitekingsq]) == $74, "White king square must be re-derived from the board")
      assert(peekbyte([blackkingsq]) == $04, "Black king square must be re-derived from the board")
      assert((peekbyte([castlerights]) & $01) == $00, "White kingside right needs the h1 rook")
      assert((peekbyte([castlerights]) & $02) == $02, "White queenside right survives with king e1 and rook a1")
      assert((peekbyte([castlerights]) & $0c) == $00, "Black rights need rooks on a8/h8")
      assert(peekbyte([enpassantsq]) == $20, "a6 en passant with a black pawn on a5 is plausible and survives")

      [enpassantsq] = $21
      jsr([SanitizeHostState], stop_on_rts = true, fail_on_brk = true)
      assert(peekbyte([enpassantsq]) == $ff, "En passant without the pushed pawn behind it must clear")

      [enpassantsq] = $55
      jsr([SanitizeHostState], stop_on_rts = true, fail_on_brk = true)
      assert(peekbyte([enpassantsq]) == $ff, "Rank-3 en passant target is impossible with white to move")
    }

    test("best-move-guard-repairs-illegal-output", "EnsureBestMoveLegal replaces a corrupt best move with a legal one") {
      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $04 = $36
      [Board88] + $60 = $b1
      [whitekingsq] = $74
      [blackkingsq] = $04
      [currentplayer] = $01
      [SearchSide] = $80
      [castlerights] = $00
      [enpassantsq] = $ff
      [SearchBestMoveRepairs] = $00

      [BestMoveFrom] = $60
      [BestMoveTo] = $50
      jsr([EnsureBestMoveLegal], stop_on_rts = true, fail_on_brk = true)
      assert(peekbyte([BestMoveFrom]) == $60, "Legal pawn push must be left untouched")
      assert(peekbyte([BestMoveTo]) == $50, "Legal pawn push destination must be left untouched")
      assert(peekbyte([SearchBestMoveRepairs]) == $00, "Legal moves must not count as repairs")

      [BestMoveFrom] = $60
      [BestMoveTo] = $30
      jsr([EnsureBestMoveLegal], stop_on_rts = true, fail_on_brk = true)
      assert(peekbyte([BestMoveFrom]) != $ff, "Guard must still produce a move")
      assert(peekbyte([BestMoveTo]) != $30, "Pawn teleport must be rejected and replaced")
      assert(peekbyte([SearchBestMoveRepairs]) == $01, "Repair counter must record the replacement")

      [BestMoveFrom] = $33
      [BestMoveTo] = $34
      jsr([EnsureBestMoveLegal], stop_on_rts = true, fail_on_brk = true)
      assert(peekbyte([BestMoveFrom]) != $33, "Move from an empty square must be rejected and replaced")
      assert(peekbyte([SearchBestMoveRepairs]) == $02, "Second repair must increment the counter")
    }

    test("headless-time-cap-exempts-beast-level", "Headless depth cap stops hard at depth 4 but lets LEVEL_BEAST iterate to the depth table") {
      [difficulty] = $02
      [IterDepth] = $04
      [TimeUp] = $00

      jsr([EngineCheckTime], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Hard difficulty hits the headless cap at iteration depth 4")
      assert(peekbyte([TimeUp]) == $01, "Hard difficulty cap should set TimeUp")

      [difficulty] = $03
      [IterDepth] = $05
      [TimeUp] = $00

      jsr([EngineCheckTime], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Beast difficulty is exempt from the headless iteration cap")
      assert(peekbyte([TimeUp]) == $00, "Beast difficulty should not set TimeUp")

      [difficulty] = $02
      [IterDepth] = $03
      [TimeUp] = $00

      jsr([EngineCheckTime], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Hard difficulty still searches below the cap")
      assert(peekbyte([TimeUp]) == $00, "Below-cap iterations should not set TimeUp")
    }

    test("headless-engine-ponder-cache-restores-board", "ChessPonderSearch caches a matching reply without committing the predicted move", timeout = 13000000) {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      [difficulty] = $00
      [currentplayer] = $00
      [SearchSide] = $00
      [SearchDepth] = $00
      [castlerights] = $00
      [enpassantsq] = $ff
      [BestMoveFrom] = $12
      [BestMoveTo] = $21
      [LastEngineMoveFrom] = $56
      [LastEngineMoveTo] = $65
      [EngineGameState] = $7e

      memfill([Board88], 128, $30)
      [Board88] + $44 = $b6
      [Board88] + $00 = $36
      [Board88] + $10 = $31
      [whitekingsq] = $44
      [blackkingsq] = $00

      a = $10
      x = $20
      jsr([ChessPonderSearch], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Ponder search should cache a reply to the predicted move")
      assert(peekbyte([PonderValid]) == $01, "Ponder cache should be valid after a matching search")
      assert(peekbyte([PonderPredictedFrom]) == $10, "Ponder should remember the predicted source")
      assert(peekbyte([PonderPredictedTo]) == $20, "Ponder should remember the predicted destination")
      assert(peekbyte([PonderReplyFrom]) != $ff, "Ponder should cache a concrete reply source")
      assert(peekbyte([PonderReplyTo]) != $ff, "Ponder should cache a concrete reply destination")
      assert(peekbyte([Board88] + $10) == $31, "Ponder search should restore the predicted pawn source")
      assert(peekbyte([Board88] + $20) == $30, "Ponder search should restore the predicted pawn destination")
      assert(peekbyte([currentplayer]) == $00, "Ponder search should restore currentplayer")
      assert(peekbyte([SearchDepth]) == $00, "Ponder search should restore SearchDepth")
      assert(peekbyte([EngineGameState]) == $7e, "Ponder search should restore EngineGameState")
      assert(peekbyte([BestMoveFrom]) == $12, "Ponder search should not publish the cached reply early")
      assert(peekbyte([BestMoveTo]) == $21, "Ponder search should preserve the prior best move")
      assert(peekbyte([LastEngineMoveFrom]) == $56, "Ponder search should preserve loop-memory source")
      assert(peekbyte([LastEngineMoveTo]) == $65, "Ponder search should preserve loop-memory destination")

      a = $10
      x = $20
      jsr([ChessPonderUse], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Matching actual move should accept the ponder reply")
      assert(peekbyte([PonderValid]) == $00, "Using the ponder reply should clear the cache")
      assert(peekbyte([BestMoveFrom]) != $12, "Using ponder should publish the cached source")
      assert(peekbyte([BestMoveFrom]) != $ff, "Using ponder should publish a valid source")
      assert(peekbyte([BestMoveTo]) != $ff, "Using ponder should publish a valid destination")
    }
  }
}
