; Game-state reporting tests for terminal and check positions.

suites {
  suite("Engine Game State") {
    symbols("/code/build/engine_harness.sym")
    load("/code/build/engine_harness.prg", strip_header = true)

    setup {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([ChessClearPositionHistory], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      memfill([WhitePieceList], 16, $ff)
      memfill([BlackPieceList], 16, $ff)
      [currentplayer] = $00
      [castlerights] = $00
      [enpassantsq] = $ff
      [SearchDepth] = $00
      [SearchSide] = $00
      [EngineGameState] = $00
      [BestMoveFrom] = $00
      [BestMoveTo] = $00
    }

    test("black-stalemate-is-reported", "ChessCheckGameState and ChessFindBestMove report stalemate") {
      ; Stalemate: black king h8, white king f7, white queen g6. Black is not
      ; in check, but h7 and g8 are covered.
      [Board88] + $07 = $36
      [Board88] + $15 = $b6
      [Board88] + $26 = $b5
      [blackkingsq] = $07
      [whitekingsq] = $15
      [WhitePieceList] + $00 = $15
      [WhitePieceList] + $01 = $26
      [WhitePieceCount] = $02
      [BlackPieceList] + $00 = $07
      [BlackPieceCount] = $01

      jsr([ChessCheckGameState], stop_on_rts = true, fail_on_brk = true)

      assert(a == $03, "Black should be stalemated")
      assert(peekbyte([EngineGameState]) == $03, "EngineGameState should report stalemate")

      jsr([ChessFindBestMove], stop_on_rts = true, fail_on_brk = true)

      assert(a == $03, "ChessFindBestMove should return stalemate state")
      assert(peekbyte([BestMoveFrom]) == $ff, "Stalemate should not report a move")
      assert(peekbyte([BestMoveTo]) == $ff, "Stalemate should not report a move")
    }

    test("black-checkmate-is-reported", "ChessCheckGameState and ChessFindBestMove report checkmate") {
      ; Checkmate: black king h8, white king f7, white queen g7.
      [Board88] + $07 = $36
      [Board88] + $15 = $b6
      [Board88] + $16 = $b5
      [blackkingsq] = $07
      [whitekingsq] = $15
      [WhitePieceList] + $00 = $15
      [WhitePieceList] + $01 = $16
      [WhitePieceCount] = $02
      [BlackPieceList] + $00 = $07
      [BlackPieceCount] = $01

      jsr([ChessCheckGameState], stop_on_rts = true, fail_on_brk = true)

      assert(a == $02, "Black should be checkmated")
      assert(peekbyte([EngineGameState]) == $02, "EngineGameState should report checkmate")

      jsr([ChessFindBestMove], stop_on_rts = true, fail_on_brk = true)

      assert(a == $02, "ChessFindBestMove should return checkmate state")
      assert(peekbyte([BestMoveFrom]) == $ff, "Checkmate should not report a move")
      assert(peekbyte([BestMoveTo]) == $ff, "Checkmate should not report a move")
    }

    test("black-king-on-a8-check-is-reported", "Game-state check handles black king on square zero") {
      ; Black king at a8 is in rook check from a1, but has legal escapes.
      [Board88] + $00 = $36
      [Board88] + $77 = $b6
      [Board88] + $70 = $b4
      [blackkingsq] = $00
      [whitekingsq] = $77
      [WhitePieceList] + $00 = $77
      [WhitePieceList] + $01 = $70
      [WhitePieceCount] = $02
      [BlackPieceList] + $00 = $00
      [BlackPieceCount] = $01

      jsr([ChessCheckGameState], stop_on_rts = true, fail_on_brk = true)

      assert(a == $01, "Black king on a8 should be reported in check")
      assert(peekbyte([EngineGameState]) == $01, "EngineGameState should report check")
    }

    test("insufficient-material-is-reported", "Bare kings are reported as draw by insufficient material") {
      [Board88] + $00 = $36
      [Board88] + $77 = $b6
      [blackkingsq] = $00
      [whitekingsq] = $77
      [WhitePieceList] + $00 = $77
      [WhitePieceCount] = $01
      [BlackPieceList] + $00 = $00
      [BlackPieceCount] = $01

      jsr([ChessCheckGameState], stop_on_rts = true, fail_on_brk = true)

      assert(a == $06, "Bare kings should be insufficient material")
      assert(peekbyte([EngineGameState]) == $06, "EngineGameState should report insufficient material")
    }
  }
}
