<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Sim6502HeadlessBridge</AssemblyName>
    <Sim6502OutputDir Condition="'$(Sim6502OutputDir)' == ''">/Users/barry/Git/sim6502/sim6502/bin/Release/net10.0</Sim6502OutputDir>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Sim6502TestRunner">
      <HintPath>$(Sim6502OutputDir)/Sim6502TestRunner.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="NLog">
      <HintPath>$(Sim6502OutputDir)/NLog.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Antlr4.Runtime.Standard">
      <HintPath>$(Sim6502OutputDir)/Antlr4.Runtime.Standard.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="CommandLine">
      <HintPath>$(Sim6502OutputDir)/CommandLine.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
</Project>
